name = "web-2fa-authenticator"
compatibility_date = "2024-05-01"

# 用于 Pages Functions 本地开发：
# 复制为 wrangler.toml 并填写你的 KV 命名空间 id/preview_id

kv_namespaces = [
  { binding = "AUTH_KV", id = "<your_kv_id>", preview_id = "<your_kv_preview_id>" }
]

[vars]
# === 推荐：单一管理员密钥（同时承担同步写入鉴权 + 云端浏览鉴权 + 分享写入鉴权） ===
# ADMIN_KEY = "your-admin-master-key"

# === 同步访问模式 ===
# strict（默认）= 读取也需要 ADMIN_KEY；普通访客无法下载任何同步密文
# open          = 读取公开，写入仍需鉴权（旧行为，与早期部署兼容）
# SYNC_MODE = "strict"

# === 全站访问口令（可选） ===
# 启用后所有页面/API 需先验证 cookie；与 ADMIN_KEY 相互独立
# 管理员页只控制是否启用，口令内容始终来自这里
# ACCESS_GATE = "your-site-password"

# === 分享默认有效期（秒，<=0 表示永久，可选） ===
# SHARE_TTL = "86400"

# === 旧版兼容字段（不需要可不设） ===
# SYNC_TOKEN     = "legacy-token"          # 与 ADMIN_KEY 等价的旧名，二者任一匹配即通过
# KV_ADMIN_KEY   = "legacy-kv-admin-key"   # 旧的云端浏览专用密钥
